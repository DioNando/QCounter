<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".QCounterApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.QCounter">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.QCounter">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Raccourcis statiques (appui long sur l'icône du lanceur). -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- Activité trampoline sans UI pour les raccourcis : enregistre puis se ferme. -->
        <activity
            android:name=".QuickRecordActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- Widget écran d'accueil (Glance) — variante par défaut (deux lignes). -->
        <receiver
            android:name=".ui.widget.QCounterWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/qcounter_widget_info" />
        </receiver>

        <!-- Widget — variante compacte sur une seule ligne. -->
        <receiver
            android:name=".ui.widget.QCounterRowWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/qcounter_widget_row_info" />
        </receiver>

        <!-- Widget — variante 2×1 (3 boutons seuls). -->
        <receiver
            android:name=".ui.widget.QCounterButtonsWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/qcounter_widget_buttons_info" />
        </receiver>

        <!-- Écran de configuration du widget 1×1 (choix de l'action). -->
        <activity
            android:name=".ui.widget.CompactWidgetConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.QCounter">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- Widget — variante 1×1. -->
        <receiver
            android:name=".ui.widget.QCounterCompactWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/qcounter_widget_compact_info" />
        </receiver>

        <!-- Tuile Quick Settings pour saisie rapide. -->
        <service
            android:name=".ui.tile.QCounterTileService"
            android:exported="true"
            android:icon="@drawable/ic_logo"
            android:label="@string/tile_qs_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
    </application>

</manifest>
